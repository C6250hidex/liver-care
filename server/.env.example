# ========================
# DATABASE (Aiven MySQL)
# ========================
DB_HOST=your-aiven-mysql-host.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=your-aiven-db-password
DB_NAME=liver_care_db
DB_PORT=21814
DB_SSL=true
DB_CA_PATH=path/to/aiven-ca.pem
# Or, if you prefer base64-encoded CA cert:
# DB_CA_BASE64=base64-encoded-ca-cert

# ========================
# SERVER CONFIGURATION
# ========================
PORT=5000
NODE_ENV=production

# Client URL for CORS and email verification links
CLIENT_URL=https://liver-care-client.onrender.com
ENABLE_SCHEMA_APPLY=false

# ========================
# JWT & AUTHENTICATION
# ========================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# ========================
# EMAIL SERVICE (Brevo/Sendinblue)
# ========================
BREVO_API_KEY=your-brevo-api-key
SENDER_EMAIL=no-reply@livercare.ai
SENDER_NAME=LiverCare AI
REPLY_TO_EMAIL=support@livercare.ai

# ========================
# DEPLOYMENT (Render.com)
# ========================
# Render will automatically set these:
# - PORT (defaults to 5000)
# - NODE_ENV (set to production)
